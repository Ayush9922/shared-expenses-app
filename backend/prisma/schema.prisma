// Prisma schema file for Shared Expenses App

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  createdGroups      Group[]            @relation("GroupCreator")
  memberships        GroupMember[]
  paidExpenses       Expense[]          @relation("ExpensePayer")
  createdExpenses    Expense[]          @relation("ExpenseCreator")
  debts              ExpenseParticipant[]
  paidSettlements    Settlement[]       @relation("SettlementPayer")
  receivedSettlements Settlement[]      @relation("SettlementReceiver")
  importSessions     ImportSession[]

  @@index([email])
}

model Group {
  id          String   @id @default(uuid())
  name        String
  createdBy   String
  createdAt   DateTime @default(now())

  // Relations
  creator     User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]

  @@index([createdBy])
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  // Relations
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
  @@index([groupId, userId])
}

model Expense {
  id           String   @id @default(uuid())
  title        String
  description  String?
  amount       Decimal  // Financial precision
  currency     String   // e.g. "INR", "USD"
  exchangeRate Decimal  @default(1.0)
  date         DateTime
  paidBy       String
  groupId      String
  createdBy    String
  createdAt    DateTime @default(now())

  // Relations
  payer        User                 @relation("ExpensePayer", fields: [paidBy], references: [id])
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator      User                 @relation("ExpenseCreator", fields: [createdBy], references: [id])
  participants ExpenseParticipant[]

  @@index([groupId])
  @@index([paidBy])
}

model ExpenseParticipant {
  id         String   @id @default(uuid())
  expenseId  String
  userId     String
  amountOwed Decimal  // How much this user owes for this expense
  splitType  String   // "EQUAL", "EXACT", "PERCENTAGE"
  splitValue Decimal? // The value input for split type (e.g. 50 for 50%, or 300 for exact)

  // Relations
  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([userId])
}

model Settlement {
  id           String   @id @default(uuid())
  payerId      String
  receiverId   String
  amount       Decimal
  currency     String   // e.g. "INR"
  exchangeRate Decimal  @default(1.0)
  date         DateTime @default(now())
  groupId      String
  createdAt    DateTime @default(now())

  // Relations
  payer        User   @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver     User   @relation("SettlementReceiver", fields: [receiverId], references: [id])
  group        Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([payerId])
  @@index([receiverId])
}

model ImportSession {
  id             String        @id @default(uuid())
  fileName       String
  status         String        // "PENDING", "RESOLVED", "FINALIZED", "FAILED"
  processedCount Int           @default(0)
  anomalyCount   Int           @default(0)
  userId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  user           User          @relation(fields: [userId], references: [id])
  issues         ImportIssue[]

  @@index([userId])
}

model ImportIssue {
  id              String    @id @default(uuid())
  importSessionId String
  rowIndex        Int
  rowData         String    // JSON stringified row data
  fieldName       String?
  issueType       String    // e.g. "DUPLICATE_EXPENSE", "NEGATIVE_AMOUNT", etc.
  message         String
  severity        String    // "WARNING", "ERROR"
  policyAction    String?   // "SKIP", "IMPORT", "ADJUST", etc.
  userApproved    Boolean   @default(false)
  resolvedAt      DateTime?

  // Relations
  importSession   ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)

  @@index([importSessionId])
}
